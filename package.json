{
  "name": "multi-lingua",
  "version": "0.7.1",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3456",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "version": "node -e \"const fs=require('fs'),v=require('./package.json').version,mcp=JSON.parse(fs.readFileSync('./mcp-server/package.json','utf8'));mcp.version=v;fs.writeFileSync('./mcp-server/package.json',JSON.stringify(mcp,null,2)+'\\n');\" && git add mcp-server/package.json",
    "mcp:install": "cd mcp-server && npm install",
    "mcp:build": "cd mcp-server && npm run build",
    "mcp:start": "cd mcp-server && npm run start",
    "mcp:start:http": "cd mcp-server && npm run start:http",
    "mcp:dev": "cd mcp-server && npm run dev",
    "mcp:dev:http": "cd mcp-server && npm run dev:http"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@types/node": "^24.0.7",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.3",
    "html-entities": "^2.6.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.5.0",
    "next-swagger-doc": "^0.4.1",
    "nodemailer": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^19.2.4",
    "sqlite3": "^5.1.7",
    "swagger-ui-react": "^5.31.0",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.9",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.4.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18"
  }
}
