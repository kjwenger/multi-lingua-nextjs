{
  "name": "multi-lingua-mcp",
  "version": "0.1.0",
  "description": "MCP server for Multi-Lingua vocabulary management",
  "main": "dist/index.js",
  "bin": {
    "multi-lingua-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup index.ts --format cjs --platform node --target node20 --out-dir dist --no-splitting",
    "type-check": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc --noEmit",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.7",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
